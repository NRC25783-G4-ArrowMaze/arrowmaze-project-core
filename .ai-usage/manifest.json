    {
      "id": "2026-06-13-001",
      "date": "2026-06-13",
      "month": "2026-06",
      "title": "Game Session Scoring (A5)",
      "file": "2026-06/2026-06-13_game-session-scoring.md",
      "duration": {
        "value": 45,
        "unit": "minutes",
        "estimated": true
      },
      "aiModel": "Claude Sonnet 4.5",
      "tool": "claude.ai",
      "phase": "Game Logic & Specification",
      "feature": "A5",
      "context": "Diseño y especificación del cálculo de puntuación en GameSession",
      "methodology": "Spec-Driven Development (SDD) con Q&A estructurada",
      "deliverables": [
        "game-session-scoring.feature — Gherkin BDD con 14 escenarios + tabla de 10 ejemplos",
        "Matriz de 14 decisiones cerradas (0 pendientes)",
        "Fórmula de cálculo validada y consolidada"
      ],
      "status": "ready_for_implementation",
      "iterationRounds": 3,
      "iterationPhases": [
        "Elicitación",
        "Desambiguación",
        "Confirmación scope"
      ],
      "decisions": {
        "total": 14,
        "closed": 12,
        "outOfScope": 2
      },
      "keyDecisions": [
        {
          "id": 1,
          "decision": "Score como VO inmutable del Domain",
          "rationale": "Regla de negocio pura, reemplazable sin mutable internals"
        },
        {
          "id": 6,
          "decision": "Penalización lineal",
          "rationale": "Simple, predecible, escala gradualmente"
        },
        {
          "id": 7,
          "decision": "Reset de racha con cualquier éxito",
          "rationale": "Perdonar después de error, reset psicológico"
        },
        {
          "id": 8,
          "decision": "Unidad de tiempo: ticks",
          "rationale": "Determinista, no depende del UI ni sistema operativo"
        },
        {
          "id": 9,
          "decision": "Clamp negativo a 0",
          "rationale": "Usuario ganó pero con errores → score ≥ 0"
        }
      ],
      "formula": "finalScore = max(0, max(0, BASE − ticksUsed × DECAY) − Σ(BASE_PENALTY × consecutiveFailsAt(i)) + (flawlessVictory ? FLAWLESS_BONUS : 0))",
      "constants": {
        "BASE": 1000,
        "DECAY": 2,
        "BASE_PENALTY": 10,
        "FLAWLESS_BONUS": 500
      },
      "scopeOutOfBounds": [
        "Scaling por nivel",
        "Persistencia histórica (high score)",
        "Tipos de constantes inyectables"
      ],
      "keywords": [
        "scoring",
        "game-session",
        "formula",
        "sdd",
        "decision-matrix"
      ]
    },
    {
      "id": "2026-06-13-002",
      "date": "2026-06-13",
      "month": "2026-06",
      "title": "Game End Detection (A4)",
      "file": "2026-06/2026-06-13_a4-game-end-detection.md",
      "duration": {
        "value": 30,
        "unit": "minutes",
        "estimated": true
      },
      "aiModel": "Claude Opus 4.7",
      "tool": "claude.ai",
      "phase": "Game Logic & Specification",
      "feature": "A4",
      "context": "Detección de victoria y derrota, consumo de movimientos",
      "methodology": "Iterative design review con structured elicitation",
      "deliverables": [
        "Diseño arquitectónico de GameSession aggregate (Domain)",
        "PlayMoveUseCase orchestrator (Application layer)",
        "Extension de LevelData con campo allowedMoves",
        "a4-game-end-detection.feature — Gherkin BDD con 12 escenarios + 1 outline + tabla"
      ],
      "status": "architecture_defined",
      "iterationRounds": 2,
      "keyDecisions": [
        {
          "decision": "GameSession como nuevo aggregate root",
          "details": "Sin contener Board o Arrow[]",
          "rationale": "Separación de responsabilidades"
        },
        {
          "decision": "PlayMoveUseCase como wrapper",
          "details": "De AdvanceArrowUseCase",
          "rationale": "Preserva SRP (Single Responsibility Principle)"
        },
        {
          "decision": "Consumo de movimiento: blocked=SÍ, system_error=NO",
          "details": "blocked outcome consume move; success=false por error NO consume",
          "rationale": "Semántica clara de errores vs outcomes"
        },
        {
          "decision": "Victoria tiene precedencia sobre derrota",
          "details": "En último movimiento (empate)",
          "rationale": "Lógica determinista, sin ambigüedad"
        },
        {
          "decision": "evaluateStatus() es idempotente",
          "details": "En estados terminales siempre retorna mismo resultado",
          "rationale": "Garantiza consistencia en llamadas múltiples"
        }
      ],
      "keywords": [
        "game-end-detection",
        "move-consumption",
        "victory",
        "defeat",
        "aggregate-root"
      ]
    }
